# Hugging Face Spaces compliant Dockerfile
# UID 1000, Port 7860

FROM python:3.10-slim

# --- ROOT phase: system deps + user creation ---
RUN apt-get update && \
    apt-get install -y --no-install-recommends libmagic1 && \
    apt-get clean && \
    rm -rf /var/lib/apt/lists/*

RUN useradd -m -u 1000 user

ENV HOME=/home/user \
    PATH=/home/user/.local/bin:$PATH

WORKDIR /home/user/app

# Install 'uv' (ultrafast rust-based package manager) to completely bypass HF's brutal pip compile throttling
COPY requirements_HF.txt .
RUN pip install --no-cache-dir uv && \
    uv pip install --system --no-cache -r requirements_HF.txt

# Copy application source (as root, with correct ownership)
COPY *.py .

# Create a resilient startup wrapper AS ROOT before switching user
RUN printf '#!/bin/sh\nuvicorn main_HF:app --host 0.0.0.0 --port 7860 || { echo "UVICORN CRASHED - see stacktrace above"; sleep 3600; }\n' \
    > /home/user/app/start.sh && \
    chmod +x /home/user/app/start.sh && \
    chown -R user:user /home/user/app

# --- USER phase: everything below runs as UID 1000 ---
USER user

EXPOSE 7860

CMD ["/home/user/app/start.sh"]
